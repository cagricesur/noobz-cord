  "components": {
    "schemas": {
      "ActivationRequest": {
        "required": [
          "token",
          "tokenHash",
          "pin"
        ],
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "format": "uuid"
          },
          "tokenHash": {
            "type": "string"
          },
          "pin": {
            "type": "string"
          }
        }
      },
      "ActivationResponse": {
        "type": "object"
      },
      "ConferenceResponse": {
        "type": "object",
        "properties": {
          "server": {
            "type": [
              "null",
              "string"
            ]
          },
          "room": {
            "type": [
              "null",
              "string"
            ]
          },
          "token": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "JwtTokenData": {
        "required": [
          "token",
          "refreshToken",
          "expires"
        ],
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string",
            "format": "uuid"
          },
          "expires": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "LoginRequest": {
        "required": [
          "contact",
          "password"
        ],
        "type": "object",
        "properties": {
          "contact": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "password": {
            "maxLength": 16,
            "minLength": 8,
            "type": "string"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "userData": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/UserData"
              }
            ]
          },
          "tokenData": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/JwtTokenData"
              }
            ]
          }
        }
      },
      "OkResult": {
        "type": "object",
        "properties": {
          "statusCode": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "RefreshTokenRequest": {
        "required": [
          "refreshToken"
        ],
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "RefreshTokenResponse": {
        "type": "object",
        "properties": {
          "tokenData": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/JwtTokenData"
              }
            ]
          }
        }
      },
      "RegistrationRequest": {
        "required": [
          "contact",
          "name",
          "password",
          "passwordConfirm"
        ],
        "type": "object",
        "properties": {
          "contact": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "name": {
            "maxLength": 20,
            "minLength": 5,
            "pattern": "^[A-Za-z][A-Za-z0-9]*$",
            "type": "string"
          },
          "password": {
            "maxLength": 16,
            "minLength": 8,
            "pattern": "^(?=.*\\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[!@#$%^&*()_+\\-=\\[\\]{};':\"\\\\|,.<>?`~]).+$",
            "type": "string"
          },
          "passwordConfirm": {
            "type": "string"
          }
        }
      },
      "RegistrationResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "format": "uuid"
          },
          "tokenHash": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "ServiceError": {
        "required": [
          "code"
        ],
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          }
        }
      },
      "TranslationData": {
        "required": [
          "name",
          "language",
          "value"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      },
      "UserData": {
        "required": [
          "name",
          "role"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "role": {
            "$ref": "#/components/schemas/UserRoleEnum"
          }
        }
      },
      "UserRoleEnum": {
        "enum": [
          "Member",
          "Moderator",
          "Admin"
        ]
      }
    }
  },
  "tags": [
    {
      "name": "Conference"
    },
    {
      "name": "Token"
    },
    {
      "name": "Translation"
    },
    {
      "name": "User"
    }
  ]
}