                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/KeyValuePairOfstringAndstring"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/Parameter/AddMissingTranslations": {
      "post": {
        "tags": [
