  },
  "components": {
    "schemas": {
      "ActivationRequest": {
        "type": "object",
        "properties": {
          "token": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "token": {
            "type": "string"
          }
        }
      },
      "KeyValuePairOfstringAndstring": {
        "required": [
          "key",
          "value"
        ],
        "type": "object",
        "properties": {
          "key": {
            "type": [
              "null",
              "string"
            ]
          },
          "value": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "LoginRequest": {
        "required": [
          "password",
          "contact"
        ],
        "type": "object",
        "properties": {
          "password": {
            "maxLength": 10,
            "minLength": 8,
            "type": "string"
          },
          "contact": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          }
        }
      },
      "RegistrationRequest": {
        "required": [
          "name",
          "password",
          "passwordConfirm",
          "contact"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 20,
            "minLength": 5,
            "pattern": "^[A-Za-z][A-Za-z0-9]*$",
            "type": "string"
          },
          "password": {
            "maxLength": 10,
            "minLength": 8,
            "type": "string"
          },
          "passwordConfirm": {
            "type": "string"
          },
          "contact": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Auth"
    },
    {
      "name": "Cache"
    },
    {
      "name": "Parameter"
    }
  ]
